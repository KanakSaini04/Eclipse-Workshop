/* ===== General Page Styling ===== */
body {
  font-family: "Poppins", sans-serif;
  background: linear-gradient(135deg, #2575fc, #6a11cb);
  height: 100vh;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* ===== Header ===== */
header {
  text-align: center;
  color: #ffffff;
  margin-bottom: 20px;
}

header h1 {
  font-size: 32px;
  letter-spacing: 1px;
  text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.2);
}

/* ===== Form Container ===== */
main {
  background: #ffffff;
  padding: 40px 50px;
  border-radius: 15px;
  width: 350px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.2);
}

/* ===== Form Elements ===== */
form {
  display: flex;
  flex-direction: column;
}

label {
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

input[type="text"],
input[type="password"] {
  padding: 12px;
  border: 1px solid #ccc;
  border-radius: 8px;
  margin-bottom: 20px;
  outline: none;
  font-size: 14px;
  transition: 0.3s ease;
}

/* Focus Effect */
input[type="text"]:focus,
input[type="password"]:focus {
  border-color: #2575fc;
  box-shadow: 0 0 8px rgba(37, 117, 252, 0.5);
}

/* ===== Button Styling ===== */
button {
  background: linear-gradient(90deg, #6a11cb, #2575fc);
  color: white;
  border: none;
  padding: 12px;
  font-size: 16px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  transition: 0.3s ease;
}

button:hover {
  background: linear-gradient(90deg, #2575fc, #6a11cb);
  transform: translateY(-1px);
}

/* ===== Responsive Design ===== */
@media (max-width: 450px) {
  main {
    width: 90%;
    padding: 30px 25px;
  }

  header h1 {
    font-size: 26px;
  }
}
